{
  "name": "openclaw-deploy",
  "version": "0.1.0",
  "description": "One-command deployment toolkit for hardened, private OpenClaw AI agents",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "openclaw-deploy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "agent-twitter-client": "^0.0.18",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "discord.js": "^14.25.1",
    "dockerode": "^4.0.4",
    "handlebars": "^4.7.8",
    "imapflow": "^1.2.13",
    "inquirer": "^12.3.2",
    "minisearch": "^7.2.0",
    "nodemailer": "^8.0.2",
    "open": "^11.0.0",
    "ora": "^8.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "viem": "^2.47.4",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.34",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "oxlint": "^0.15.4",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "keywords": [
    "openclaw",
    "moltbot",
    "ai-agent",
    "deployment",
    "security",
    "docker"
